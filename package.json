    "verify": "tsx scripts/cli.ts verify",
    "followup": "tsx scripts/cli.ts followup",
    "serve": "tsx scripts/cli.ts serve",
    "worker": "tsx scripts/cli.ts worker",
    "workers": "tsx scripts/cli.ts workers",
    "console": "tsx scripts/cli.ts console",
