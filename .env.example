# Admin API（与 parrot-server 对齐）
LOOP_API_BASE_URL=http://localhost:4001

# 【人工】从浏览器复制 Admin 登录后的 Cookie（过期需重配）
# 例：parrot_admin_auth_token=eyJ...
LOOP_ADMIN_COOKIE=parrot_admin_auth_token=

# 半自动门禁：禁止 true 跳过【人工】批准
LOOP_AUTO_APPROVE=false

# ── Agent 运行时分流 ──────────────────────────────────────────
# feedback / task / verify / followup → DeepSeek（默认）
# coding → Cursor Agent CLI（改业务代码）
# 可用 LOOP_DEFAULT_RUNTIME=cursor 强制非 coding 也走 Cursor
LOOP_DEFAULT_RUNTIME=deepseek

# DeepSeek（OpenAI 兼容 Chat Completions + tools）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_ROUNDS=12

# Cursor Agent（仅 coding；鉴权二选一）
#   A) 本机一次：agent login
#   B) 写 API Key（Cursor Dashboard → API Keys）：
CURSOR_API_KEY=
LOOP_AGENT_BIN=agent
# 可选模型，例如 sonnet-4 / gpt-5；留空用 agent 默认
LOOP_AGENT_MODEL=

# 业务代码工作区根（coding / verifier）。留空 = loop-engineer 上一级
LOOP_WORKSPACE_ROOT=
