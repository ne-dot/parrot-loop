# ── Feedback 数据源（HTTP sync；与上游反馈系统解耦）──────────────
# API 基址（不含 path）
LOOP_API_BASE_URL=http://localhost:4001
# 列表接口 path（相对基址）
LOOP_FEEDBACK_LIST_PATH=/api/admin/feedback
# 查询参数：type / status（逗号分隔）
LOOP_FEEDBACK_TYPE=bug
LOOP_FEEDBACK_STATUSES=open,in_progress
# 写入 artifacts/feedback 的 source 字段
LOOP_FEEDBACK_SOURCE=site_feedback

# 【人工】从浏览器复制登录后的 Cookie（过期需重配）
# 格式：<cookie名>=<值>
LOOP_ADMIN_COOKIE_NAME=auth_token
LOOP_ADMIN_COOKIE=auth_token=

# 也可跳过 HTTP sync：手动把反馈 md 放进 artifacts/feedback/，再跑 feedback/task

# 半自动门禁：禁止 true 跳过【人工】批准（全量）；high 仍可系统自动批
LOOP_AUTO_APPROVE=false

# 同类 Bug signal 分窗（毫秒）；默认 24h。非 active 且超窗 → 新建 signal
# LOOP_SIGNAL_DEDUP_WINDOW_MS=86400000

# ── 业务代码工作区（coding / verifier）──────────────────────────
# 含各业务仓库的父目录。留空 = loop-engineer 上一级（monorepo 常见布局）
LOOP_WORKSPACE_ROOT=
# task.repos 为空时的 fallback（逗号分隔；单仓可写 .）
LOOP_DEFAULT_REPOS=.
# verifier git diff 基准分支
LOOP_DEFAULT_BRANCH=main
# followup 草稿落款
LOOP_FOLLOWUP_SIGN_OFF=—— Loop Engineer

# ── Control Plane / 事件总线 ────────────────────────────────────
LOOP_SERVE_PORT=4010
LOOP_SERVE_HOST=127.0.0.1
# loop 自有 Redis（docker compose 默认映射宿主机 6380）
LOOP_REDIS_URL=redis://127.0.0.1:6380
# 本版默认关闭定时 sync；>0 仅预留
LOOP_SCHEDULER_INTERVAL_MS=0
# 批准后是否自动入队 coding
LOOP_AUTO_AFTER_APPROVE=true
# coding 内环 Verify：连续失败上限（默认 3）
LOOP_CODING_VERIFY_MAX_ATTEMPTS=3
# Web / API 鉴权（可选；空=本地免 token）
LOOP_API_TOKEN=
LOOP_CORS_ORIGIN=http://127.0.0.1:4011,http://localhost:4011
# Console 开发代理目标（console/.env 或环境变量）
# VITE_LOOP_API_PROXY=http://127.0.0.1:4010
# VITE_LOOP_API_TOKEN=

# ── Agent 运行时分流 ────────────────────────────────────────────
# feedback / task / verify / followup → DeepSeek（默认）
# coding → Cursor Agent CLI（改业务代码）
# 可用 LOOP_DEFAULT_RUNTIME=cursor 强制非 coding 也走 Cursor
LOOP_DEFAULT_RUNTIME=deepseek

# DeepSeek（OpenAI 兼容 Chat Completions + tools）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_ROUNDS=12

# Cursor Agent（仅 coding；鉴权二选一）
#   A) 本机一次：agent login
#   B) 写 API Key（Cursor Dashboard → API Keys）：
CURSOR_API_KEY=
LOOP_AGENT_BIN=agent
# 可选模型，例如 sonnet-4 / gpt-5；留空用 agent 默认
LOOP_AGENT_MODEL=
